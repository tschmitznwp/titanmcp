{
  "name": "titan-mcp",
  "version": "1.1.0",
  "description": "Read-only MCP server for the Titan 3000 Web API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "titan-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "verify": "node scripts/verify-coverage.mjs",
    "smoke": "node scripts/smoke-stdio.mjs && node scripts/smoke-http.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
