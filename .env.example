# Base URL of the Titan 3000 Web API (no trailing slash)
TITAN_BASE_URL=http://titanapi-dev.nwpipe.com

# Credentials issued for this integration (sent as X-App-Id / X-Api-Key headers).
# Fill these in yourself — never commit real values.
TITAN_APP_ID=
TITAN_API_KEY=

# Port for the Streamable HTTP MCP endpoint (default 8585)
TITAN_MCP_PORT=8585
